{
  "expo": {
    "name": "LexiAid",
    "slug": "lexiaid",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "lexiaid",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lexiaid.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B6E6E",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.lexiaid.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-document-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
