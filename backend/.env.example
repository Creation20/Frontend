# ============================================================
# LexiAid Backend — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# ----------------------------------------------------------------
# Database — PostgreSQL via Prisma
# Local:   postgresql://postgres:password@localhost:5432/lexiaid
# Neon.tech (free): postgres://user:pass@ep-xxx.neon.tech/lexiaid?sslmode=require
# Supabase (free): postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
# ----------------------------------------------------------------
DATABASE_URL="postgresql://postgres:password@localhost:5432/lexiaid"

# ----------------------------------------------------------------
# JWT Secrets — Generate strong random strings:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ----------------------------------------------------------------
JWT_ACCESS_SECRET="your-super-secret-access-token-key-change-this"
JWT_REFRESH_SECRET="your-super-secret-refresh-token-key-change-this"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ----------------------------------------------------------------
# Google Gemini AI — FREE at https://aistudio.google.com
# Free tier: 15 requests/min, 1,500 requests/day, 1M tokens/day
# ----------------------------------------------------------------
GEMINI_API_KEY="your-gemini-api-key-from-aistudio-google-com"
GEMINI_MODEL="gemini-1.5-flash"

# ----------------------------------------------------------------
# CORS — Origin of your Expo/React Native frontend
# For local Expo Go: use your machine's LAN IP e.g. http://192.168.1.x:8081
# ----------------------------------------------------------------
CORS_ORIGIN="http://localhost:8081"

# ----------------------------------------------------------------
# File Uploads
# ----------------------------------------------------------------
MAX_FILE_SIZE_MB=20
UPLOAD_DIR="./uploads"
